# Discord Bot
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_GUILD_ID=optional-guild-id-for-dev

# Anthropic
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# GitHub (optional, for repo context fetching)
GITHUB_TOKEN=

# Limits
MAX_SESSIONS_PER_USER=3
MAX_REQUESTS_PER_MINUTE=10
MAX_CONTEXT_TOKENS=100000

# Script Execution (disabled by default)
ENABLE_SCRIPT_EXECUTION=false
SCRIPT_TIMEOUT_MS=30000

# Ollama
# Local:  OLLAMA_BASE_URL=http://localhost:11434  (no API key needed)
# Cloud:  OLLAMA_BASE_URL=https://ollama.com      (get an API key at ollama.com/settings/api)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# Git Author Identity (optional — overrides auto-detected identity)
# If GITHUB_TOKEN is set, the bot auto-resolves the token owner's name and noreply email
# so commits are linked to the GitHub account (fixes Vercel "could not associate committer" errors).
# These fields override the auto-detected values when set explicitly.
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# Storage
DB_PATH=./data/bot.db
