# Discord Bot
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_GUILD_ID=optional-guild-id-for-dev

# Anthropic — API keys managed via /admin addkey in Discord
# Optionally pre-load keys here (comma-separated), or leave blank
ANTHROPIC_API_KEYS=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# GitHub (optional, for repo context fetching)
GITHUB_TOKEN=ghp_xxx

# Admin Discord User IDs (comma-separated)
ADMIN_USER_IDS=123456789

# Limits
MAX_SESSIONS_PER_USER=3
MAX_REQUESTS_PER_MINUTE=10
MAX_CONTEXT_TOKENS=100000

# Storage
DB_PATH=./data/bot.db
